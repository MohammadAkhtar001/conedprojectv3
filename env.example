# Required by SEC EDGAR — they enforce a contact email in the User-Agent.
# Generic UAs get 403 "Host not in allowlist".  Format: "Name email@domain"
SEC_USER_AGENT=Utility Benchmark Pipeline you@example.com

# Optional — enables AI-driven verification and insights step at the end.
# If not set, those features are disabled and the run still produces data.
ANTHROPIC_API_KEY=

# Optional — when "1", the pipeline uses Playwright (headless Chromium) for
# JS-rendered pages.  Required for J.D. Power and most utility CSR landing pages.
USE_PLAYWRIGHT=1

# Optional — minimum acceptable confidence score.  Values below this come back
# with confidence_score set but are flagged in the UI.
MIN_CONFIDENCE=0.50
